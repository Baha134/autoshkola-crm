{
  "name": "autoshkola-crm",
  "version": "1.0.0",
  "description": "CRM для автошколы",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon --ignore whatsapp-session/ --ignore prisma/dev.db --ignore prisma/dev.db-journal src/app.js",
    "client": "cd client && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run client\"",
    "migrate": "prisma migrate dev",
    "seed": "node prisma/seed.js",
    "build": "cd client && npm install && npm run build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "5",
    "@whiskeysockets/baileys": "^6.7.18",
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "nodemon": "^3.1.0",
    "qrcode-terminal": "^0.12.0",
    "sqlite3": "^6.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "prisma": "5"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
