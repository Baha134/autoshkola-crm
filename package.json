{
  "name": "autoshkola-crm",
  "version": "1.0.0",
  "description": "CRM для автошколы",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon --ignore whatsapp-session/ --ignore prisma/dev.db --ignore prisma/dev.db-journal src/app.js",
    "client": "cd client && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run client\"",
    "migrate": "prisma migrate dev",
    "seed": "node prisma/seed.js"
  },
